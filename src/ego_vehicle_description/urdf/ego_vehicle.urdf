<?xml version="1.0"?>

<robot name="ego_vehicle">

  <!--
    base_link corresponds to the AlpaSim ego rig.

    Origin:
      Center of the rear axle projected onto the ground plane.

    Axes:
      +x forward
      +y left
      +z up
  -->

  <link name="base_link"/>

  <!-- Lower vehicle body -->
  <link name="vehicle_body">
    <visual>
      <origin xyz="1.35 0.0 0.70" rpy="0 0 0"/>
      <geometry>
        <box size="4.80 2.00 1.40"/>
      </geometry>
      <material name="vehicle_blue">
        <color rgba="1.00 0.80 0.00 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_vehicle_body" type="fixed">
    <parent link="base_link"/>
    <child link="vehicle_body"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Cabin -->
  <link name="vehicle_cabin">
    <visual>
      <origin xyz="1.20 0.0 1.35" rpy="0 0 0"/>
      <geometry>
        <box size="2.40 1.75 0.75"/>
      </geometry>
      <material name="window_dark">
        <color rgba="0.08 0.10 0.13 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_vehicle_cabin" type="fixed">
    <parent link="base_link"/>
    <child link="vehicle_cabin"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Front-left wheel -->
  <link name="wheel_front_left">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.36" length="0.24"/>
      </geometry>
      <material name="tire_black">
        <color rgba="0.03 0.03 0.03 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_wheel_front_left" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_front_left"/>
    <origin xyz="2.80 0.94 0.36" rpy="0 0 0"/>
  </joint>

  <!-- Front-right wheel -->
  <link name="wheel_front_right">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.36" length="0.24"/>
      </geometry>
      <material name="tire_black"/>
    </visual>
  </link>

  <joint name="base_to_wheel_front_right" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_front_right"/>
    <origin xyz="2.80 -0.94 0.36" rpy="0 0 0"/>
  </joint>

  <!-- Rear-left wheel -->
  <link name="wheel_rear_left">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.36" length="0.24"/>
      </geometry>
      <material name="tire_black"/>
    </visual>
  </link>

  <joint name="base_to_wheel_rear_left" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_rear_left"/>
    <origin xyz="0 0.94 0.36" rpy="0 0 0"/>
  </joint>

  <!-- Rear-right wheel -->
  <link name="wheel_rear_right">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.36" length="0.24"/>
      </geometry>
      <material name="tire_black"/>
    </visual>
  </link>

  <joint name="base_to_wheel_rear_right" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_rear_right"/>
    <origin xyz="0 -0.94 0.36" rpy="0 0 0"/>
  </joint>

</robot>
